{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Rutas": {
    "FirmasCliNotificaciones": "D:\\\\Produccion\\\\App\\\\evmNetV2\\\\FirmasClientesNotificaciones\\\\"
  },
  "Apis": {

    //------------Produccion
    "apiAforos": "https://evmappis.emvarias.com.co/ApiAforos",
    //"apiCertificados": "https://evmappis.emvarias.com.co/ApiCertificados",
    "apiIdentity": "https://evmappis.emvarias.com.co/ApiIdentity",

    //------------Dllo
    //"apiIdentity": "https://localhost:7188",
    //"apiAforos": "https://localhost:7080",
    "apiCertificados": "https://localhost:7201",
    //"apiRH": "https://localhost:7095"
    "apiRH": "https://evmappis.emvarias.com.co/ApiRH"


  },
  "RouteH": {
    "App": {
      "Name": "RouteH Web Admin",
      "Environment": "Production",
      "DefaultCulture": "es-CO",
      "DefaultRoute": "/dashboard",
      "EnableDetailedErrors": false,
      "EnableDebugMode": false
    },

    "Api": {
      "BusinessApi": {
        "BaseUrl": "https://evmappis.emvarias.com.co/ApiRH/",
        "TimeoutSeconds": 30,
        "Version": "v1",
        "EnableLogging": true
      },

      "SecurityApi": {
        "BaseUrl": "https://security.routeh.com/",
        "TimeoutSeconds": 30,
        "Version": "v1",
        "EnableLogging": true
      }
    },

    "Authentication": {
      "TokenExpirationMinutes": 60,
      "RefreshTokenExpirationDays": 7,
      "EnableRefreshToken": true
    },

    "Localization": {
      "DefaultCulture": "es-CO",
      "SupportedCultures": [
        "es-CO",
        "en-US"
      ]
    },

    "Features": {
      "EnableNotifications": true,
      "EnableAuditLogs": true,
      "EnableFileDownloads": true,
      "EnableAdvancedSearch": true
    },

    "Pagination": {
      "DefaultPageSize": 10,
      "MaxPageSize": 100
    }
  }
}
